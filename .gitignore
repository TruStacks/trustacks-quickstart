.env.local
*.local.env

# Editor + OS noise
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Built artifacts (none today; reserved for future helm/quickstart-<ver>.tgz)
dist/
charts/*/charts/
charts/*/Chart.lock
